# Code-only GitHub tracking
/*
!/.gitignore
!/Assets/
Assets/*
!/Assets/Scripts.meta
!/Assets/Scripts/
!/Assets/Scripts/**
!/Packages/
!/Packages/**
!/ProjectSettings/
!/ProjectSettings/**

# Re-ignore local/editor-generated files inside tracked code folders
Assets/Scripts/.vs/
Assets/Scripts/**/.vs/
Assets/Scripts/**/bin/
Assets/Scripts/**/obj/
Assets/Scripts/**/bin.meta
Assets/Scripts/**/obj.meta
Assets/Scripts/settings.json
